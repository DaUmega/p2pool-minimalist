# Rename to setup.conf and fill in your values, then:
#   sudo ./manage.sh build && sudo ./manage.sh start

# ── Monero binary ─────────────────────────────────────────────────────────────
# Latest: https://www.getmonero.org/downloads/
MONERO_URL=https://downloads.getmonero.org/gui/monero-gui-linux-x64-v0.18.4.7.tar.bz2
MONERO_SHA256=4573defcf21b0daeea0e9c7213540012c7d1186e829daf991fa8edfc5033dc08

# ── p2pool binary ─────────────────────────────────────────────────────────────
# Latest: https://github.com/SChernykh/p2pool/releases
P2POOL_URL=https://github.com/SChernykh/p2pool/releases/download/v4.14/p2pool-v4.14-linux-x64.tar.gz
P2POOL_SHA256=e64f6f774dc35352b8ae4397ccdb92ce0cc935cdfb100eac58d44e49f8796a01

# ── Tari suite binary ─────────────────────────────────────────────────────────
# Latest: https://github.com/tari-project/tari/releases
TARI_URL=https://github.com/tari-project/tari/releases/download/v5.2.1/tari_suite-5.2.1-mainnet-c79f555-linux-x86_64.zip
TARI_SHA256=8c9460ed3084851fecb16e977ba010f7a52d26aac61ddda831d35dbf9e091494

# ── Wallet addresses ──────────────────────────────────────────────────────────
WALLET=4...             # Monero wallet address (required)
TARI_WALLET=            # Tari wallet address — leave blank to disable merge mining

# ── Mode settings ─────────────────────────────────────────────────────────────
MONERO_PRUNED=true          # true = pruned (~100 GB), false = full node
P2POOL_MODE=mini            # main | mini | nano
RAM_LIMIT=                  # RAM limit when Tari merge mining is enabled (default 3g)
LOG_MAX_SIZE=               # Maximum log file size (100k, 100M, 10G) before rotation. 500M default, 0 to disable.

# ── Tor ───────────────────────────────────────────────────────────────────────
# Exposes monerod RPC/P2P and p2pool stratum as hidden services,
# and routes outbound monerod transactions through Tor.
TOR_ENABLED=true
