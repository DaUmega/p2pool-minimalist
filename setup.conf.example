# ── Rename to setup.conf ──────────────────────────────────────────────────────────
# Edit these values before running: ./manage.sh build && ./manage.sh start

# Your Monero wallet address (required)
WALLET=4...

# monerod binary URL and SHA-256 checksum for verification
# Get the latest release from: https://www.getmonero.org/downloads/
MONERO_URL=https://downloads.getmonero.org/gui/monero-gui-linux-x64-v0.18.4.7.tar.bz2
MONERO_SHA256=4573defcf21b0daeea0e9c7213540012c7d1186e829daf991fa8edfc5033dc08

# p2pool binary URL and SHA-256 checksum for verification
P2POOL_URL=https://github.com/SChernykh/p2pool/releases/download/v4.14/p2pool-v4.14-linux-x64.tar.gz
P2POOL_SHA256=e64f6f774dc35352b8ae4397ccdb92ce0cc935cdfb100eac58d44e49f8796a01

# p2pool mode: main | mini | nano
P2POOL_MODE=mini

# Route monerod outbound tx through Tor and expose as hidden service: true | false
TOR_ENABLED=true
